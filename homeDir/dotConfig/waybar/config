  		"default": "â–¶"
   	},
   	"status-icons": {
  		"paused": "âڈ¸"
   	},
  },
  "position": "bottom",
  "spacing": 0,
  "temperature": {
    "critical-threshold": 90,
    "format": "{icon}",
    "format-icons": [
      "ï‹‹",
      "ï‹ٹ",
      "ï‹‰",
      "ï‹ˆ",
      "ï‹‡"
    ],
    "interval": 5,
    "warning-threshold": 75
  },
  "tray": {
    "icon-size": 13,
