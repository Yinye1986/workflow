{
  "layer": "top",
  "position": "top",
  "modules-left": [
    "image",
    "niri/workspaces",
    "wlr/taskbar",
    "cava"
  ],
  "modules-center": [
  ],
  "modules-right": [
    "group/info",
    "tray",
    "clock",
    "mpris"
  ],
  "backlight": {
    "device": "intel_backlight",
    "format": "{icon}",
    "format-icons": [
      "َ°›©",
      "َ±©ژ",
      "َ±©ڈ",
      "َ±©گ",
      "َ±©‘",
      "َ±©’",
      "َ±©“",
      "َ±©”",
