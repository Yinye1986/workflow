    "tooltip": false
  },
  "wireplumber#sink": {
    "format": "{icon}",
    "format-icons": [
      "َ°•؟",
      "َ°–€",
      "َ°•¾"
    ],
    "format-muted": "َ°‌ں",
    "max-volume": 200,
    "on-click": "pavucontrol",
    "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
    "scroll-step": 1,
    "tooltip-format": "{volume}%"
  },
  "wireplumber#source": {
    "format": "ï„°",
    "format-muted": "ï„±",
