    "size": 14
  },
  "memory": {
    "format": "{icon}",
    "format-icons": [
      "î؟…"
    ],
    "interval": 2,
    "states": {
      "critical": 80
    }
  },
  "network": {
    "format-disconnected": "َ°–ھ",
    "format-ethernet": "َ°ˆ€",
    "format-wifi": "َ°–©",
    "interval": 5,
    "on-click": "foot nmtui",
    "tooltip-format": "{ifname} {bandwidthDownBytes}",
    "tooltip-format-disconnected": "Disconnected",
    "tooltip-format-ethernet": "{ifname} {bandwidthDownBytes} َ°ˆ€",
    "tooltip-format-wifi": "{essid} {bandwidthDownBytes} ï‡«"
