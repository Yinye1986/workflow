
set $volume_up adb shell input keyevent 24
set $volume_down adb shell input keyevent 25
set $brightness_up adb shell input keyevent 221
set $brightness_down adb shell input keyevent 220

set $mode_streamdeck "\
<span foreground='$color10'><b>󰕾 Shift:</b></span> \
<span foreground='$color10'><b>󰃠  Ctrl:</b></span>"

mode --pango_markup $mode_streamdeck {
	$bindsym Shift+u exec $volume_up
	$bindsym Shift+e exec $volume_down
	$bindsym Control+u exec $brightness_up
	$bindsym Control+e exec $brightness_down
	$bindsym Shift+Up exec $volume_up
	$bindsym Shift+Down exec $volume_down
	$bindsym Control+Up exec $brightness_up
	$bindsym Control+Down exec $brightness_down
    $bindsym Escape mode "default"
}
$bindsym $mod+F2 mode $mode_streamdeck
